{
  "name": "volt-frontend-assets",
  "private": true,
  "type": "module",
  "scripts": {
    "build:alpine": "node scripts/sync-alpine.mjs",
    "build:tailwind": "tailwindcss -c tailwind.config.cjs -i src/tailwind.css -o ../public/assets/vendor/tailwindcss/tailwind.min.css --minify",
    "build:vendor": "npm run build:alpine && npm run build:tailwind",
    "update:vendor": "npm update alpinejs tailwindcss && npm run build:vendor"
  },
  "dependencies": {
    "alpinejs": "^3.14.0",
    "tailwindcss": "^3.4.0"
  }
}
